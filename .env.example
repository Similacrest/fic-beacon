# Calibre library path (absolute path to your Calibre library folder).
# Mounted READ-ONLY into the app; READ-WRITE into the fetcher container only.
CALIBRE_LIBRARY_PATH=/path/to/your/calibre/library

# Where the fetcher's FanFicFare personal.ini (site logins) lives. Defaults to ./fetcher/config.
# FETCHER_CONFIG_PATH=/path/to/fetcher/config

# Fetcher service URL (the isolated FanFicFare + calibredb container).
# BEACON_FETCHER_URL=http://fetcher:8080
# Fetches are async (FanFicFare can take ~15 min): how often to poll a running job, and
# when to give up on one (seconds).
# BEACON_FETCHER_POLL_INTERVAL=30
# BEACON_FETCHER_JOB_TIMEOUT=1200
# Fetcher container only — base seconds for its 3-try exponential backoff on transient errors.
# FETCHER_RETRY_BASE_SECONDS=30

# Optional: change the default port
BEACON_PORT=8000

# Optional: set your domain (used in feed generation)
BEACON_BASE_URL=http://localhost:8000

# Optional: timezone for drop/poll schedules (IANA name, e.g. Europe/Tallinn).
# Unset → UTC in a stock container.
# BEACON_TZ=Europe/Tallinn

# Optional: feed secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# BEACON_FEED_SECRET=your-secret-here
